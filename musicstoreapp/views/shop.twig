{% extends "layout.twig" %}

{% block title %} Tienda – uoMusic {% endblock %}

{% block main_container %}
    <div class="row">
        <div id="custom-search-input">
            <form method="get" action="/shop">
                <div class="input-group col-xs-8 col-sm-6 col-md-4 col-lg-5 pull-right">
                    <input id="search" type="text" class="search-query form-control"
                           placeholder="Nombre de la canción" name="search"/>
                    <span class="input-group-btn">
                        <button class="btn" type="submit">
                            <span class="glyphicon glyphicon-search"></span>
                        </button>
                    </span>
                </div>
            </form>
        </div>
    </div>

    <h2>Canciones</h2>
    <div class="row">
        {% for song in songs %}
            <div class="col-xs-6 col-sm-6 col-md-4 col-lg-3" style="margin-bottom: 30px;">
                <div style="width:200px">
                    <a href="/songs/{{ song._id }}">
                        <img src="/covers/{{ song._id }}.png" alt="logo" class="img-responsive img-thumbnail"/>
                        <div style="margin-top: 10px; color: #333;"><strong>{{ song.title }}</strong></div>
                        <div class="small text-muted">{{ song.author }}</div>
                        <div class="text-right" style="color: #2e6da4;"><strong>{{ song.price }} €</strong></div>
                    </a>
                    <form method="post" action="/songs/favorites/add/{{ song._id }}">
                        <button type="submit" class="btn btn-xs btn-primary" style="margin-top: 10px;">
                            Añadir a favoritos
                        </button>
                    </form>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="row text-center">
        <ul class="pagination">
            {% for page in pages %}
                <li class="page-item" id="pi-{{ page }}">
                    <a class="page-link" href="/shop/?page={{ page }}">{{ page }}</a>
                </li>
            {% endfor %}
            <script>
                $("#pi-" + "{{ currentPage }}").addClass("active");
            </script>
        </ul>
    </div>
{% endblock %}
